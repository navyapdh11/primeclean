{
  "functions": {
    "app/api/create-checkout/route.ts": { "maxDuration": 15 },
    "app/api/stripe/portal/route.ts": { "maxDuration": 10 }
  },
  "rewrites": [{ "source": "/api/(.*)", "destination": "/api/$1" }],
  "headers": [
    { "source": "/(.*)", "headers": [{ "key": "X-Frame-Options", "value": "DENY" }] }
  ]
}
